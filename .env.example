# Linear API Key - Get from: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_xxxxxxxxxxxx

# GitHub Organization
GITHUB_ORG=ruh-ai

# Base branch to create PRs against
TARGET_BRANCH=dev

# Directory to clone/manage repos
REPOS_DIR=./repos

# Log directory
LOGS_DIR=./logs

# Poll interval in minutes (default: 60)
POLL_INTERVAL_MINUTES=60

# Max tickets to process in parallel (default: 2)
MAX_CONCURRENT_TICKETS=2


# GitHub Personal Access Token (for gh CLI inside Docker)
GH_TOKEN=github_pat_xxxxxxxxxxxx

# Claude Code OAuth Token (from `claude setup-token`)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxxxxxxxxxxx

# SSH key path (for git clone inside Docker)
SSH_KEY_PATH=~/.ssh/id_ed25519
